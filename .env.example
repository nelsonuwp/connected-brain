# This file defines the complete configuration schema for the application.
# Copy to `.env` and fill in values.
# `.env` must match this structure exactly.
# Do NOT commit `.env`.

# =========================================================
# === APPLICATION ===
# =========================================================

# type: string | required | values: development, staging, production
APP_ENV=development

# type: integer | required | default: 3000
APP_PORT=3000

# type: string | optional
APP_BASE_URL=


# =========================================================
# === LOGGING ===
# =========================================================

# type: string | default: info | values: debug, info, warn, error
LOG_LEVEL=info


# =========================================================
# === JIRA ===
# =========================================================

# type: string | required
JIRA_BASE_URL=

# type: string | required
JIRA_USERNAME=

# type: string | required | secret
JIRA_API_TOKEN=

# type: integer | default: 365
JIRA_LOOKBACK_DAYS=365


# =========================================================
# === OPS-AGENT (ticket viewer + persona drafter) ===
# =========================================================
# LLM calls use OPENROUTER_API_KEY + MODEL_WORKHORSE + TEMPERATURE_WORKHORSE
# (already defined above in the LLM section — no new keys needed)

# type: string | default: 127.0.0.1
OPS_AGENT_HOST=127.0.0.1

# type: integer | default: 8080
OPS_AGENT_PORT=8080


# =========================================================
# === JSM-SYNC (Postgres mirror of APTUM JSM project) ===
# =========================================================

# type: string | required | secret — password for the jsm_sync Postgres user
POSTGRES_PASSWORD=localdev

# type: string | required — asyncpg connection string
DATABASE_URL=postgresql://jsm_sync:localdev@localhost:5432/jsm_sync

# type: string | default: APTUM — Jira project key to sync
JIRA_PROJECT=APTUM

# type: integer | default: 5 — concurrent Jira API requests
JIRA_SEMAPHORE_LIMIT=5


# =========================================================
# === SALESFORCE ===
# =========================================================

# type: string | required
SALESFORCE_DOMAIN=

# type: string | required
SALESFORCE_USERNAME=

# type: string | required | secret
SALESFORCE_PASSWORD=

# type: string | required | secret
SALESFORCE_TOKEN=

# type: string | required
SALESFORCE_CONSUMER_KEY=

# type: string | required | secret
SALESFORCE_CONSUMER_SECRET=


# =========================================================
# === ZOOMINFO ===
# =========================================================

# type: string | required
ZOOMINFO_CLIENT_ID=

# type: string | required | secret
ZOOMINFO_CLIENT_SECRET=

# type: string | required | secret
ZOOMINFO_REFRESH_TOKEN=


# =========================================================
# === LLM ===
# =========================================================

# type: string | required
MODEL_REASONING=

# type: string | required
MODEL_WORKHORSE=

# type: string | required
MODEL_NANO=

# type: string | required
MODEL_SEARCH=

# type: float | default: 1.0
TEMPERATURE_REASONING=1.0

# type: float | default: 0.4
TEMPERATURE_WORKHORSE=0.4

# type: float | default: 0.3
TEMPERATURE_NANO=0.3

# type: float | default: 0.1
TEMPERATURE_SEARCH=0.1

# type: string | required | secret
OPENROUTER_API_KEY=


# =========================================================
# === OCEAN DATABASE ===
# =========================================================

# type: string | required
OCEAN_DB_SERVER=

# type: string | required
OCEAN_DB_NAME=

# type: string | required (db-sync accepts USERNAME or USER; oceanClient uses USER)
OCEAN_DB_USERNAME=

# type: string | required | secret — use double-quotes if password has special chars (^, #, etc.)
OCEAN_DB_PASSWORD=


# =========================================================
# === GENERIC DATABASE (FALLBACK) ===
# =========================================================

# type: string | optional | secret
DB_PASSWORD=


# =========================================================
# === Supabase DATABASE (FALLBACK) ===
# =========================================================

# type: string | optional
SUPABASE_DB_URL=

# type: string | optional
SUPABASE_URL=

# type: string | optional | secret
SUPABASE_KEY=


# =========================================================
# === AZURE BILLING DATABASE ===
# =========================================================

# type: string | required
AZURE_BILLING_DB_NAME=

# type: string | required
AZURE_BILLING_DB_USERNAME=

# type: string | required | secret
AZURE_BILLING_DB_PASSWORD=


# =========================================================
# === SSH TUNNEL ===
# =========================================================

# type: string | required
SSH_HOST=

# type: integer | default: 22
SSH_PORT=22

# type: string | required
SSH_USERNAME=

# type: string | required | secret
SSH_PASSWORD=


# =========================================================
# === FEATURE FLAGS ===
# =========================================================

# type: boolean | default: false
FEATURE_USE_FALLBACK_EMBEDDING=false

# type: boolean | default: false
FEATURE_ENABLE_CLUSTERING=false


# =========================================================
# === TUNABLES / LIMITS ===
# =========================================================

# type: integer | default: 3
LLM_MAX_RETRIES=3

# type: integer | default: 30
FINANCIAL_QUERY_TIMEOUT_SECONDS=30

# type: integer | optional
MIN_SIGNALS_THRESHOLD=

# type: boolean | default: false
NEWS_DEBUG_STOP_AFTER_WAVE_2=false


# =========================================================
# === CLUSTERING CONFIG ===
# =========================================================

# type: string | optional
CLUSTER_CONFIG=

# type: string | optional
CLUSTER_INTERPRET_MODEL=


# =========================================================
# === OPTIONAL SSH (AZURE BILLING) ===
# =========================================================

# type: string | optional
AZURE_BILLING_SSH_HOST=

# type: integer | optional
AZURE_BILLING_SSH_PORT=

# type: string | optional
AZURE_BILLING_SSH_USERNAME=

# type: string | optional | secret
AZURE_BILLING_SSH_PASSWORD=


# ========================================================
# === Miscellaneous ===
# ========================================================

# type: string | optional
CONTEXT7_API_KEY=


# =========================================================
# === MICROSOFT AUTHENTICATION ===
# =========================================================

# type: string | optional
MS_CLIENT_ID=

# type: string | optional
MS_TENANT_ID=

# type: string | optional | secret
MS_SESSION_SECRET=

# type: string | optional | secret
MS_CLIENT_SECRET=

# type: string | optional
MS_EMAIL=

# type: string | optional
MS_REDIRECT_URI=

# type: string | optional — Outlook / Graph base URL (e.g. when using MCAS proxy)
OUTLOOK_BASE_URL=
