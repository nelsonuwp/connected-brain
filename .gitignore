# ── CREDENTIALS ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OBSIDIAN ──────────────────────────────────────────────────────────────────
# Commit: plugin list, settings, appearance (portable config)
# Ignore: workspace state (machine-specific, changes constantly)
vault/**/.obsidian/workspace.json
vault/**/.obsidian/workspace-mobile.json
vault/**/.obsidian/cache
# Ignore Whisper API key
vault/.obsidian/plugins/whisper/data.json

# ── PYTHON ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/
.mypy_cache/

# ── OS NOISE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── EDITOR ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swovault/.obsidian/plugins/whisper/data.json

# ── JSM-SYNC ──────────────────────────────────────────────────────────────────
projects/jsm-sync/postgres_data/
projects/jsm-sync/logs/
*.log
